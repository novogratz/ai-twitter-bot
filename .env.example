# ──────────── Identity ────────────
BOT_HANDLE=kzer_ai

# ──────────── AI provider ────────────
# claude / codex / gemini. Authenticate with `codex login` (or claude/gemini login).
AI_CLI=codex
NEWS_MODEL=gpt-5.4
HOTAKE_MODEL=gpt-5.4
REPLY_MODEL=gpt-5.4-mini
PRIORITY_REPLY_MODEL=gpt-5.4
QUOTE_MODEL=gpt-5.4-mini
ROAST_MODEL=gpt-5.4-mini

# ──────────── Daily caps — original content ────────────
MAX_NEWS_PER_DAY=12
MAX_HOTAKES_PER_DAY=6
MAX_BREAKOUTS_PER_DAY=4
MAX_SPICY_PER_DAY=4

# ──────────── Daily caps — reshare + engagement ────────────
MAX_QUOTES_PER_DAY=30
MAX_RETWEETS_PER_DAY=60
MAX_REPLIES_PER_CYCLE=25

# ──────────── Per-cycle quotas ────────────
FOLLOW_BLAST_PER_CYCLE=30
LIKE_BOT_PER_CYCLE=22
RETWEET_MIN_LIKES=10
RETWEET_MAX_AGE_HOURS=18
QUOTE_MAX_AGE_HOURS=18

# ──────────── Rate limits ────────────
LLM_MIN_SECONDS_BETWEEN_CALLS=45
LLM_MAX_CALLS_PER_HOUR=60

# ──────────── Self-modification toggles ────────────
ENABLE_AI_MAINTENANCE=1
ENABLE_AI_DISCOVERY=1

# ──────────── Language ────────────
# en / fr / mixed. Replies always match parent tweet language regardless.
CONTENT_LANG_PRIMARY=en

# Twitter API tokens NOT REQUIRED — the bot uses browser automation only.
# Leave blank unless you're extending with API features yourself.
