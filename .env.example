# No API keys needed for subscription CLI mode.
# Defaults are ChatGPT Plus / Codex-safe.
AI_CLI=codex
NEWS_MODEL=gpt-5.4
REPLY_MODEL=gpt-5.4-mini
HOTAKE_MODEL=gpt-5.4-mini
QUOTE_MODEL=gpt-5.4-mini
ROAST_MODEL=gpt-5.4-mini
MAX_NEWS_PER_DAY=4
MAX_HOTAKES_PER_DAY=1
MAX_QUOTES_PER_DAY=2
MAX_RETWEETS_PER_DAY=3
RETWEET_MIN_LIKES=50
LLM_MIN_SECONDS_BETWEEN_CALLS=60
LLM_MAX_CALLS_PER_HOUR=30
ENABLE_AI_MAINTENANCE=0
ENABLE_AI_DISCOVERY=0
