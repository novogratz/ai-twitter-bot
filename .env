# No Anthropic API key needed — the bot uses a local AI CLI.

# Provider selection. User mandate 2026-05-14: codex primary, opencode
# fallback. Always. Opencode/big-pickle is slow (4-8 min/call) and times
# out the whole ladder (180s × 3 = 9 min silent). Codex errors return in
# seconds when locked, so the fallback to opencode is cheap. Do NOT swap
# primary to opencode "temporarily" — caused a 7-hour silent gap.
BOT_HANDLE=cryptoiadecode
AI_CLI=codex
LLM_FALLBACK_CLI=opencode
LLM_FALLBACK_MODEL=opencode/big-pickle
OPENCODE_FALLBACK_MODEL=opencode/big-pickle
OPENCODE_FALLBACK2_MODEL=ollama/qwen3-coder

# 2026-05-13 mandate: FR only, scope = IA + Crypto only (NO bourse / stocks).
# Goal = thousands of followers + thousands of likes. Crank engagement
# surfaces (follows, likes, retweets, replies). Keep news quality high but
# allow more shots on goal. Hot takes back on (memes drive virality in FR).
MAX_NEWS_PER_DAY=20
MAX_HOTAKES_PER_DAY=8
MAX_BREAKOUTS_PER_DAY=4
MAX_SPICY_PER_DAY=4
MAX_QUOTES_PER_DAY=150
MAX_RETWEETS_PER_DAY=400
MAX_REPLIES_PER_CYCLE=20
FOLLOW_BLAST_PER_CYCLE=80
LIKE_BOT_PER_CYCLE=80
RETWEET_MIN_LIKES=3
RETWEET_MAX_AGE_HOURS=24
QUOTE_MAX_AGE_HOURS=24
CONTENT_LANG_PRIMARY=fr
CONTENT_SCOPE=ai_crypto_only
NEWS_CANDIDATES=8
ENABLE_AI_MAINTENANCE=1
ENABLE_AI_DISCOVERY=1
ENABLE_CODEX_OPERATOR=1

# 2026-05-13: one shot per cycle. If the primary LLM produces garbage and
# the fallback ladder can't recover, skip the cycle entirely rather than
# burning 3 burst attempts (6+ min) on bad output.
NEWS_POSTS_PER_CYCLE=1

# Growth optimization settings
GROWTH_ENHANCEMENT=1
FOLLOW_BACK_RATIO=0.3
RETWEET_ENGAGEMENT_THRESHOLD=5
BOOST_ENGAGEMENT_POSTS=1

# Strict daily content filtering to prevent reposts of old content
RETWEET_FORCE_DAILY_ONLY=1
