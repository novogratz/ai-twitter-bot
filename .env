NEWS_MODEL=opencode/big-pickle
HOTAKE_MODEL=opencode/big-pickle
REPLY_MODEL=opencode/big-pickle
PRIORITY_REPLY_MODEL=opencode/big-pickle
QUOTE_MODEL=opencode/big-pickle
ROAST_MODEL=opencode/big-pickle

# 2026-05-08 PM user pivot: "only posts should be high quality news on
# AI / crypto / investments. avoid hot topic or shitty posts. you can go
# crazy with reposts, reposts with quote and responses." Hot takes,
# breakouts, spicy = DISABLED (cap 0). News quality gate raised to 9/10.
# 2026-05-09 PM YouTube pivot: user starting a YouTube channel that
# uses the bot's content as raw material. More news = more video angles.
# More reposts = more research material. Quality stays high but cap up.
MAX_NEWS_PER_DAY=12
MAX_HOTAKES_PER_DAY=2
MAX_BREAKOUTS_PER_DAY=2
MAX_SPICY_PER_DAY=2
MAX_QUOTES_PER_DAY=120
MAX_RETWEETS_PER_DAY=300
MAX_REPLIES_PER_CYCLE=12
FOLLOW_BLAST_PER_CYCLE=50
LIKE_BOT_PER_CYCLE=50
RETWEET_MIN_LIKES=3
RETWEET_MAX_AGE_HOURS=24
QUOTE_MAX_AGE_HOURS=24
CONTENT_LANG_PRIMARY=fr
NEWS_CANDIDATES=5
ENABLE_AI_MAINTENANCE=1
ENABLE_AI_DISCOVERY=1
ENABLE_CODEX_OPERATOR=1

# Growth optimization settings
GROWTH_ENHANCEMENT=1
FOLLOW_BACK_RATIO=0.3
RETWEET_ENGAGEMENT_THRESHOLD=5
BOOST_ENGAGEMENT_POSTS=1

# Strict daily content filtering to prevent reposts of old content
RETWEET_FORCE_DAILY_ONLY=1
