TWITTER_ACCESS_TOKEN_SECRET=P6SoDb8lozoT4FIQn6ii1TBEDIyYrhTeq3CtREliEJVTV
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAALix9AEAAAAAyvrDO%2BbxJdVK9vBUxK8S%2B5iuOsg%3DMwLJEAmRu32NN6eQ57zexnDVFA2UCFcLHLOTbJ8BraA8W57FGp

# No Anthropic API key needed — the bot uses a local AI CLI.

# Provider selection. User mandate 2026-05-14: codex primary, opencode
# fallback. Always. Opencode/big-pickle is slow (4-8 min/call) and times
# out the whole ladder (180s × 3 = 9 min silent). Codex errors return in
# seconds when locked, so the fallback to opencode is cheap. Do NOT swap
# primary to opencode "temporarily" — caused a 7-hour silent gap.
BOT_HANDLE=cryptoiadecode
# 2026-05-15 PM: Claude Sonnet as primary (4s/call, quality output).
# Fallback to opencode → routes to ollama HTTP / qwen3.6 directly
# when Claude returns rate-limit / error / empty.
AI_CLI=claude
LLM_FALLBACK_CLI=opencode
NEWS_MODEL=claude-sonnet-4-6
HOTAKE_MODEL=claude-sonnet-4-6
REPLY_MODEL=claude-sonnet-4-6
PRIORITY_REPLY_MODEL=claude-sonnet-4-6
QUOTE_MODEL=claude-sonnet-4-6
ROAST_MODEL=claude-haiku-4-5-20251001
# Local fallback model. qwen3.6:35b-a3b (both base and uncensored variant)
# returns empty response via ollama's API — appears to be a thinking-mode
# model whose output isn't surfaced through /api/generate. qwen3-coder:30b
# works reliably: 5-6s warm, real output, ~18GB. Confirmed 2026-05-15.
OLLAMA_MODEL=qwen3-coder:30b
# 2026-05-15: opencode CLI is invoked WITHOUT --model. opencode uses
# its own local default (configured to qwen via ollama). big-pickle was
# timing out at 300s on every reply — 0 posts in 3.5h. Letting opencode
# pick its own model = ~50s end-to-end for a reply. Smoke tested.
# 600s ceiling so qwen3.6:35b-a3b never gets killed mid-generation on
# the big ~25k-char news/reply prompts. User mandate 2026-05-15: "I want
# it to be able to complete the news or messages all the time".
LLM_TIMEOUT_SECONDS=600

# 2026-05-13 mandate: FR only, scope = IA + Crypto only (NO bourse / stocks).
# Goal = thousands of followers + thousands of likes. Crank engagement
# surfaces (follows, likes, retweets, replies). Keep news quality high but
# allow more shots on goal. Hot takes back on (memes drive virality in FR).
# 2026-05-16 PM: more of everything — user mandate "post more, retweet
# more, quote more, but only tweets from the same day".
MAX_NEWS_PER_DAY=40
MAX_HOTAKES_PER_DAY=16
MAX_BREAKOUTS_PER_DAY=8
MAX_SPICY_PER_DAY=8
MAX_QUOTES_PER_DAY=250
MAX_RETWEETS_PER_DAY=600
MAX_REPLIES_PER_CYCLE=40
FOLLOW_BLAST_PER_CYCLE=80
LIKE_BOT_PER_CYCLE=80
RETWEET_MIN_LIKES=3
# Same-day hard cap (24h) — user 2026-05-16: "only tweets from the
# same day". Tightened from 48h. Belt-and-suspenders: escape hatches
# also removed from retweet_bot / quote_tweet_bot in the same commit.
RETWEET_MAX_AGE_HOURS=24
QUOTE_MAX_AGE_HOURS=24
FAVORITE_REPOST_MAX_AGE_MINUTES=1440
CONTENT_LANG_PRIMARY=fr
CONTENT_SCOPE=ai_crypto_only
NEWS_CANDIDATES=8
ENABLE_AI_MAINTENANCE=1
ENABLE_AI_DISCOVERY=1
ENABLE_CODEX_OPERATOR=1

# 2026-05-13: one shot per cycle. If the primary LLM produces garbage and
# the fallback ladder can't recover, skip the cycle entirely rather than
# burning 3 burst attempts (6+ min) on bad output.
NEWS_POSTS_PER_CYCLE=1

# Growth optimization settings
GROWTH_ENHANCEMENT=1
FOLLOW_BACK_RATIO=0.3
RETWEET_ENGAGEMENT_THRESHOLD=5
BOOST_ENGAGEMENT_POSTS=1

# Strict daily content filtering to prevent reposts of old content
RETWEET_FORCE_DAILY_ONLY=1
